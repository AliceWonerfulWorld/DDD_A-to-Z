# Elixir チャットサービス 環境変数サンプル
# 本番（Cloud Run）では runtime.exs がこれらの値を必須で読み込む

# PostgreSQL 接続URL
DATABASE_URL=postgres://lang_war:YOUR_PASSWORD@localhost:5432/lang_war

# Phoenix のセッション署名に使う秘密鍵（64文字以上推奨）
# 生成方法: mix phx.gen.secret
SECRET_KEY_BASE=your_secret_key_base_here

# WebSocket 接続を許可するフロントエンドのオリジン
ALLOWED_ORIGIN=http://localhost:5173

# リッスンポート（Cloud Run は自動でセットされる）
PORT=4000

# DB コネクションプール数
POOL_SIZE=5
