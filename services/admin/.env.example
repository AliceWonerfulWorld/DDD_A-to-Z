APP_NAME="Lang War Admin"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8081

LOG_CHANNEL=stack
LOG_LEVEL=debug

DB_CONNECTION=pgsql
DATABASE_URL=postgresql://lang_war:lang_war_password@localhost:5432/lang_war

# Basic認証（必須・未設定時はfail closed）
ADMIN_USER=admin
ADMIN_PASSWORD=changeme

CACHE_STORE=array
SESSION_DRIVER=cookie
SESSION_LIFETIME=120
