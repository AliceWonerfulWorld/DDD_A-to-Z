GCP_PROJECT_ID=your-gcp-project-id

NEON_DATABASE_URL=postgresql://user:pass@host/db?sslmode=require
GITHUB_CLIENT_ID=your-github-oauth-app-client-id
GITHUB_CLIENT_SECRET=your-github-oauth-app-client-secret
GITHUB_REDIRECT_URL=https://your-cloud-run-url/api/auth/github/callback
# openssl rand -base64 64 で生成したランダムな文字列を指定
AUTH_COOKIE_SECRET=replace-with-at-least-64-byte-random-secret
GITHUB_TOKEN_ENCRYPTION_SECRET=replace-with-strong-random-secret
